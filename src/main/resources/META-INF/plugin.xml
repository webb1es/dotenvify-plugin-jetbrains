<idea-plugin>
    <id>dev.webbies.dotenvify</id>
    <name>DotEnvify</name>
    <vendor email="hello@webbies.dev" url="https://webbies.dev">Webbies</vendor>

    <description><![CDATA[
    Convert raw key-value pairs into properly formatted .env files — directly in your IDE.

    <h3>Features</h3>
    <ul>
        <li>Parse multiple input formats (KEY=VALUE, KEY VALUE, line pairs, quoted values)</li>
        <li>Optional <code>export</code> prefix</li>
        <li>Smart quoting for URLs and values with spaces</li>
        <li>Alphabetical sorting</li>
        <li>Filter: ignore lowercase keys, URL-only values</li>
        <li>Preserve specific keys from existing .env</li>
        <li>Incremental backups before overwriting</li>
        <li>Tool window with live preview</li>
    </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <group id="DotEnvify.EditorPopupMenu" text="DotEnvify" popup="true">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <action id="DotEnvify.ConvertSelection"
                    class="dev.webbies.dotenvify.actions.ConvertSelectionAction"
                    text="Convert Selection to .env"
                    description="Convert selected key-value text to .env format">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt E"/>
            </action>
        </group>

        <group id="DotEnvify.ProjectViewPopupMenu" text="DotEnvify" popup="true">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <action id="DotEnvify.ConvertFile"
                    class="dev.webbies.dotenvify.actions.ConvertFileAction"
                    text="Convert File to .env"
                    description="Parse this file and convert to .env format"/>
        </group>

        <group id="DotEnvify.ToolsMenu" text="DotEnvify" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <reference ref="DotEnvify.ConvertSelection"/>
            <reference ref="DotEnvify.ConvertFile"/>
        </group>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="DotEnvify"
                    anchor="bottom"
                    factoryClass="dev.webbies.dotenvify.ui.DotEnvifyToolWindowFactory"
                    secondary="false"/>

        <applicationService serviceImplementation="dev.webbies.dotenvify.settings.DotEnvifySettings"/>
        <projectService serviceImplementation="dev.webbies.dotenvify.settings.DotEnvifyProjectSettings"/>
        <projectService serviceImplementation="dev.webbies.dotenvify.diagnostics.EnvFileWatcher"/>

        <applicationConfigurable
                parentId="tools"
                instance="dev.webbies.dotenvify.settings.DotEnvifySettingsConfigurable"
                id="dev.webbies.dotenvify.settings.global"
                displayName="DotEnvify"/>

        <projectConfigurable
                parentId="dev.webbies.dotenvify.settings.global"
                instance="dev.webbies.dotenvify.settings.DotEnvifyProjectSettingsConfigurable"
                id="dev.webbies.dotenvify.settings.project"
                displayName="Project Settings"/>
    </extensions>
</idea-plugin>
